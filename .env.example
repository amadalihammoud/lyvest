# Configuração do Ecommerce Ly Vest
# Renomeie este arquivo para .env na raiz do projeto

# --- AMBIENTE ---
NODE_ENV=development

# --- SUPABASE (Público - OK expor no cliente) ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- SUPABASE (Servidor - NUNCA expor no cliente!) ---
# Use apenas em API Routes ou Server Components
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- SEGURANÇA INTERNA (Webhooks) ---
# Chave secreta para proteger rotas internas como /api/erp/sync-order
INTERNAL_API_KEY=sua_chave_secreta_super_segura_123
# Segredo para verificar a assinatura do webhook de pagamento (fail-closed em produção)
# PAYMENT_WEBHOOK_SECRET=whsec_xxx
# Segredo enviado pelo ERP (Bling/Tiny) no header x-webhook-secret
# ERP_WEBHOOK_SECRET=erp_secret_xxx

# --- CORS (funções serverless em api/*.js) ---
# Origem canônica do app (usada na allowlist de CORS)
NEXT_PUBLIC_APP_URL=https://lyvest.com.br
# Origens extras permitidas, separadas por vírgula (ex.: domínio de preview)
# CORS_ALLOWED_ORIGINS=https://lyvest.vercel.app

# --- UPSTASH REDIS (Rate limiting + cache) ---
# Obtido na integração Upstash/Vercel. Sem estas chaves, o rate limit fica desativado (fail-open).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# --- CLERK AUTH ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- RESEND EMAIL ---
RESEND_API_KEY=re_xxx

# --- OPENAI (Server-only — NEVER use NEXT_PUBLIC_ prefix!) ---
# Used for AI size recommendation via /api/ai/size-recommendation
OPENAI_API_KEY=sk-xxx

# --- SENTRY (Monitoramento de Erros) ---
# Obtenha seu DSN em: https://sentry.io/
# SENTRY_DSN=https://[key]@[organization].ingest.us.sentry.io/[project-id]

# --- PROVEDORES (Escolha um: 'mock', 'mercadopago', 'stripe') ---
PAYMENT_PROVIDER=mock
# Mercado Pago (Se escolhido acima)
# MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx

# --- FRETE (Escolha um: 'mock', 'melhorenvio', 'frenet') ---
SHIPPING_PROVIDER=mock
# Melhor Envio (Se escolhido acima)
# MELHOR_ENVIO_TOKEN=seu_token_aqui

# --- ERP (Escolha um: 'mock', 'bling', 'tiny') ---
ERP_PROVIDER=mock
# Bling (Se escolhido acima)
# BLING_API_KEY=sua_api_key
